# ── Environment ──────────────────────────────────────────────
# "production" routes handoff email to CHATBOX_HANDOFF_TO.
# Any other value (development/staging/…) routes to CHATBOX_HANDOFF_TEST_TO.
# For the staging deploy use: APP_ENV=staging
APP_ENV=development

# ── Recipients ───────────────────────────────────────────────
# Server-side only. Never exposed to frontend.
# Live recipient – used only when APP_ENV=production.
CHATBOX_HANDOFF_TO=your-live-inbox@example.com
# Test recipient – used in development/staging. Real email is still sent,
# just to this address instead of the live one.
CHATBOX_HANDOFF_TEST_TO=your-test-inbox@example.com

# ── Provider ─────────────────────────────────────────────────
# mock  → log only, no email sent  (safe default for dev)
# smtp  → generic SMTP relay (Brevo, Mailjet, AWS SES, …)
# resend → Resend HTTP API (https://resend.com – free 3 000/mo)
MAIL_PROVIDER=mock

# ── Sender address ───────────────────────────────────────────
# For MAIL_PROVIDER=resend this must be a verified domain address.
# For MAIL_PROVIDER=smtp this is the From header (can be any value
# your relay allows).
CHATBOX_MAIL_FROM=noreply@yourdomain.com

# ── Resend (MAIL_PROVIDER=resend) ────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ── SMTP relay (MAIL_PROVIDER=smtp) ──────────────────────────
# Use any provider that supports SMTP with API-key auth, e.g.:
#   Brevo:   smtp-relay.brevo.com  port 587  user=your@email  pass=api_key
#   Mailjet: in-v3.mailjet.com     port 587  user=api_key     pass=secret_key
#   AWS SES: email-smtp.<region>.amazonaws.com  port 587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── Rate limiting ────────────────────────────────────────────
# Minimum seconds between two submissions from the same client.
HANDOFF_RATE_LIMIT_SECONDS=30
# Sliding-window cap: at most MAX_REQUESTS submissions per WINDOW_SECONDS,
# enforced per client IP and per chat session id.
HANDOFF_RATE_LIMIT_MAX_REQUESTS=5
HANDOFF_RATE_LIMIT_WINDOW_SECONDS=3600

# ── CORS (browser access control) ────────────────────────────
# Comma-separated allow-list of origins permitted to call /api/* from a
# browser. Empty = same-origin only (no cross-origin allowed). Never use "*".
# Staging: set ONLY the approved test/fake website origin, e.g.:
#   CORS_ALLOW_ORIGINS=https://staging-test-site.example.com
CORS_ALLOW_ORIGINS=

# ── Static asset serving ─────────────────────────────────────
# true  → backend also serves the bundled frontend (local/dev default).
# false → API-only backend (use this for the staging API deploy).
SERVE_STATIC=true
